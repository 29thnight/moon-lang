{
  "name": "moon-lang",
  "displayName": "Moon",
  "description": "Unity-first Moon language support for VS Code with diagnostics, snippets, script exploration, and generated C# navigation.",
  "version": "0.1.0",
  "publisher": "moon-lang",
  "icon": "icons/moon-icon.png",
  "license": "UNLICENSED",
  "repository": "https://github.com/29thnight/moon-lang",
  "homepage": "https://github.com/29thnight/moon-lang#readme",
  "bugs": {
    "url": "https://github.com/29thnight/moon-lang/issues"
  },
  "keywords": [
    "moon",
    "unity",
    "compiler",
    "language",
    "vscode"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "extensionDependencies": [
    "ms-dotnettools.csharp",
    "ms-dotnettools.csdevkit",
    "ms-dotnettools.vscode-dotnet-runtime",
    "visualstudiotoolsforunity.vstuc"
  ],
  "activationEvents": [
    "onLanguage:moon",
    "workspaceContains:**/*.mn"
  ],
  "main": "./out/extension.js",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "Syntax highlighting and snippets work in untrusted mode. Diagnostics and compilation require trust.",
      "restrictedConfigurations": [
        "moon.compilerPath"
      ]
    }
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "moon-sidebar",
          "title": "Moon",
          "icon": "icons/moon-icon.svg"
        }
      ]
    },
    "views": {
      "moon-sidebar": [
        {
          "id": "moonExplorer",
          "name": "Moon Scripts",
          "icon": "icons/moon-icon.svg"
        }
      ]
    },
    "languages": [
      {
        "id": "moon",
        "aliases": ["Moon", "moon"],
        "extensions": [".mn"],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/moon-icon.svg",
          "dark": "./icons/moon-icon.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "moon",
        "scopeName": "source.moon",
        "path": "./syntaxes/moon.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "moon",
        "path": "./snippets/moon.code-snippets"
      }
    ],
    "commands": [
      {
        "command": "moon.compileFile",
        "title": "Moon: Compile Current File"
      },
      {
        "command": "moon.compileWorkspace",
        "title": "Moon: Compile Workspace"
      },
      {
        "command": "moon.checkFile",
        "title": "Moon: Check Current File"
      },
      {
        "command": "moon.showGenerated",
        "title": "Moon: Show Generated C#"
      },
      {
        "command": "moon.visualize",
        "title": "Moon: Visualize Script Structure",
        "icon": "$(graph)"
      },
      {
        "command": "moon.refreshExplorer",
        "title": "Moon: Refresh Explorer",
        "icon": "$(refresh)"
      },
      {
        "command": "moon.graphView",
        "title": "Moon: Graph View",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "moon.insertLifecycle",
        "title": "Moon: Insert Lifecycle Block"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "moon.refreshExplorer",
          "when": "view == moonExplorer",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "moon.insertLifecycle",
          "when": "editorLangId == moon",
          "group": "1_modification@0"
        }
      ]
    },
    "keybindings": [
      {
        "command": "moon.showGenerated",
        "key": "ctrl+shift+g",
        "when": "editorLangId == moon"
      },
      {
        "command": "moon.graphView",
        "key": "ctrl+shift+v",
        "when": "editorLangId == moon"
      },
      {
        "command": "moon.insertLifecycle",
        "key": "ctrl+shift+l",
        "when": "editorLangId == moon"
      }
    ],
    "configurationDefaults": {
      "editor.tokenColorCustomizations": {
        "[*]": {
          "textMateRules": [
            { "scope": "keyword.other.moon", "settings": { "foreground": "#cf8e6d" } },
            { "scope": "keyword.control.moon", "settings": { "foreground": "#cf8e6d" } },
            { "scope": "keyword.control.import.moon", "settings": { "foreground": "#cf8e6d" } },
            { "scope": "storage.modifier.moon", "settings": { "foreground": "#cf8e6d" } },
            { "scope": "constant.language.moon", "settings": { "foreground": "#cf8e6d" } },
            { "scope": "variable.language.this.moon", "settings": { "foreground": "#cf8e6d" } },
            { "scope": "support.class.moon", "settings": { "foreground": "#16baac" } },
            { "scope": "entity.name.type.moon", "settings": { "foreground": "#bcbec4" } },
            { "scope": "entity.name.type.class.moon", "settings": { "foreground": "#16baac" } },
            { "scope": "entity.name.function.moon", "settings": { "foreground": "#56a8f5" } },
            { "scope": "entity.name.function.call.moon", "settings": { "foreground": "#57aaf7" } },
            { "scope": "entity.name.function.decorator.moon", "settings": { "foreground": "#b3ae60" } },
            { "scope": "punctuation.definition.annotation.moon", "settings": { "foreground": "#b3ae60" } },
            { "scope": "support.function.moon", "settings": { "foreground": "#56a8f5" } },
            { "scope": "constant.numeric.moon", "settings": { "foreground": "#bcbec4" } },
            { "scope": "string.quoted.double.moon", "settings": { "foreground": "#6aab73" } },
            { "scope": "constant.character.escape.moon", "settings": { "foreground": "#cf8e6d" } },
            { "scope": "comment.line.double-slash.moon", "settings": { "foreground": "#7a7e85" } },
            { "scope": "comment.block.moon", "settings": { "foreground": "#7a7e85" } },
            { "scope": "variable.other.enummember.moon", "settings": { "foreground": "#c77dbb", "fontStyle": "italic" } },
            { "scope": "variable.other.member.moon", "settings": { "foreground": "#bcbec4" } },
            { "scope": "keyword.operator.moon", "settings": { "foreground": "#bcbec4" } },
            { "scope": "punctuation.separator.moon", "settings": { "foreground": "#bcbec4" } },
            { "scope": "punctuation.bracket.angle.moon", "settings": { "foreground": "#bcbec4" } },
            { "scope": "punctuation.definition.interpolation.begin.moon", "settings": { "foreground": "#cf8e6d" } },
            { "scope": "punctuation.definition.interpolation.end.moon", "settings": { "foreground": "#cf8e6d" } },
            { "scope": "variable.other.interpolation.moon", "settings": { "foreground": "#c77dbb" } }
          ]
        }
      }
    },
    "configuration": {
      "title": "Moon",
      "properties": {
        "moon.compilerPath": {
          "type": "string",
          "default": "moonc",
          "description": "Path to the moonc compiler binary"
        },
        "moon.unityApiDbPath": {
          "type": "string",
          "default": "",
          "description": "Path to Unity API SQLite database"
        },
        "moon.checkOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Run moonc check on save"
        },
        "moon.showWarnings": {
          "type": "boolean",
          "default": true,
          "description": "Show warnings in diagnostics"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "test": "npm run compile && node --test out/test/project-config.test.js out/test/compiler-resolver.test.js out/test/completion-helpers.test.js",
    "watch": "tsc -watch -p ./",
    "package": "npx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@types/better-sqlite3": "^7.6.13",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.3.0"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.8.0"
  }
}
