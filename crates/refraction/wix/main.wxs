<?xml version='1.0' encoding='windows-1252'?>
<!--
  PrSM Language Installer
  Built with cargo-wix / WiX Toolset

  Installs:
    1. prism.exe compiler to Program Files\PrSM
    2. Adds install directory to system PATH
    3. Bundles VSIX for VS Code extension (auto-install attempted)
    4. Shows Unity package install guidance on completion
-->
<Wix xmlns='http://schemas.microsoft.com/wix/2006/wi'>

    <Product
        Id='*'
        Name='PrSM Language'
        UpgradeCode='A1B2C3D4-E5F6-7890-ABCD-EF1234567890'
        Manufacturer='PrSM Contributors'
        Language='1033'
        Codepage='1252'
        Version='3.5.5'>

        <Package Id='*'
            Keywords='Installer'
            Description='PrSM Language - Unity-first scripting language toolkit'
            Manufacturer='PrSM Contributors'
            InstallerVersion='450'
            Languages='1033'
            Compressed='yes'
            InstallScope='perMachine'
            SummaryCodepage='1252' />

        <MajorUpgrade
            Schedule='afterInstallInitialize'
            DowngradeErrorMessage='A newer version of [ProductName] is already installed. Setup will now exit.' />

        <Media Id='1' Cabinet='media1.cab' EmbedCab='yes' DiskPrompt='CD-ROM #1' />
        <Property Id='DiskPrompt' Value='PrSM Language Installation' />

        <!-- ========================================================== -->
        <!-- Directory Layout                                            -->
        <!-- ========================================================== -->

        <Directory Id='TARGETDIR' Name='SourceDir'>
            <Directory Id='ProgramFiles64Folder' Name='PFiles'>
                <Directory Id='APPLICATIONFOLDER' Name='PrSM'>
                    <Component Id='Path' Guid='B2C3D4E5-F6A7-8901-BCDE-F12345678901' KeyPath='yes'>
                        <Environment Id='PATH' Name='PATH' Value='[APPLICATIONFOLDER]'
                            Permanent='no' Part='last' Action='set' System='yes' />
                    </Component>
                    <Component Id='prism_exe' Guid='C3D4E5F6-A7B8-9012-CDEF-123456789012'>
                        <File Id='prism.exe' Name='prism.exe'
                            Source='$(var.CargoTargetBinDir)\prism.exe' KeyPath='yes' />
                    </Component>
                    <Component Id='vsix_bundle' Guid='D4E5F6A7-B8C9-0123-DEFA-234567890123'>
                        <File Id='prsm_vsix' Name='parkyoungung.prsm-lang.vsix'
                            Source='$(var.CargoTargetBinDir)\..\parkyoungung.prsm-lang-$(var.Version).vsix'
                            KeyPath='yes' />
                    </Component>
                    <Component Id='file_icon' Guid='E5F6A7B8-C9D0-1234-EFAB-345678901234'>
                        <File Id='prsm_ico' Name='prsm-file-icon.ico'
                            Source='crates\refraction\wix\prsm-file-icon.ico'
                            KeyPath='yes' />
                    </Component>
                    <Component Id='file_association' Guid='F6A7B8C9-D0E1-2345-FABC-456789012345'>
                        <RegistryValue Root='HKCR' Key='.prsm' Type='string' Value='PrSM.Script' />
                        <RegistryValue Root='HKCR' Key='PrSM.Script' Type='string' Value='PrSM Script File' />
                        <RegistryValue Root='HKCR' Key='PrSM.Script\DefaultIcon' Type='string'
                            Value='[APPLICATIONFOLDER]prsm-file-icon.ico' />
                        <RegistryValue Root='HKCR' Key='PrSM.Script\shell\open\command' Type='string'
                            Value='&quot;[APPLICATIONFOLDER]prism.exe&quot; compile &quot;%1&quot;' KeyPath='yes' />
                    </Component>
                </Directory>
            </Directory>
        </Directory>

        <!-- ========================================================== -->
        <!-- Features                                                    -->
        <!-- ========================================================== -->

        <Feature Id='Compiler' Title='PrSM Compiler' Description='prism.exe compiler and PATH registration'
            Level='1' ConfigurableDirectory='APPLICATIONFOLDER' AllowAdvertise='no'
            Display='expand' Absent='disallow'>
            <ComponentRef Id='prism_exe' />
            <ComponentRef Id='Path' />
            <ComponentRef Id='file_icon' />
            <ComponentRef Id='file_association' />
        </Feature>

        <Feature Id='VSCodeExtension' Title='VS Code Extension'
            Description='PrSM VS Code extension (VSIX). Automatically installs if VS Code is detected.'
            Level='1' AllowAdvertise='no'>
            <ComponentRef Id='vsix_bundle' />
        </Feature>

        <!-- ========================================================== -->
        <!-- Custom Actions: VS Code extension install                   -->
        <!--                                                              -->
        <!-- Root cause of earlier silent failure (verified v3.5.2 log):  -->
        <!-- `code` on PATH does not resolve inside Windows Installer's   -->
        <!-- deferred impersonation token. Even Impersonate='yes' does    -->
        <!-- not inherit the interactive user's PATH. We must invoke      -->
        <!-- code.cmd via its absolute path discovered at AppSearch time. -->
        <!-- ========================================================== -->

        <!-- Detect VS Code: User-scope installer (HKCU, default layout)  -->
        <Property Id='VSCODEPATH_USER'>
            <RegistrySearch Id='VSCodeRegistryUser' Root='HKCU'
                Key='Software\Microsoft\Windows\CurrentVersion\Uninstall\{771FD6B0-FA20-440A-A002-3B3BAC16DC50}_is1'
                Name='InstallLocation' Type='raw' />
        </Property>

        <!-- Detect VS Code: System-scope installer (HKLM, 64-bit)        -->
        <Property Id='VSCODEPATH_SYS'>
            <RegistrySearch Id='VSCodeRegistrySys' Root='HKLM'
                Key='Software\Microsoft\Windows\CurrentVersion\Uninstall\{EA457B21-F73E-494C-ACAB-524FDE069978}_is1'
                Name='InstallLocation' Type='raw' Win64='yes' />
        </Property>

        <!-- Combine: prefer User installer, fall back to System.         -->
        <!-- Both SetProperty elements target the same property           -->
        <!-- (VSCODEPATH) but must have distinct CustomAction names so    -->
        <!-- WiX does not collide them. Action attributes provide the     -->
        <!-- explicit override.                                           -->
        <SetProperty Id='VSCODEPATH' Action='SetVSCODEPATHFromUser'
            Value='[VSCODEPATH_USER]' After='AppSearch' Sequence='both'>
            <![CDATA[VSCODEPATH_USER]]>
        </SetProperty>
        <SetProperty Id='VSCODEPATH' Action='SetVSCODEPATHFromSys'
            Value='[VSCODEPATH_SYS]' After='AppSearch' Sequence='both'>
            <![CDATA[NOT VSCODEPATH_USER AND VSCODEPATH_SYS]]>
        </SetProperty>

        <!-- Install the VSIX via absolute path to code.cmd. The outer    -->
        <!-- cmd.exe /c wrapper is only needed so that a missing VS Code  -->
        <!-- installation never brings the entire MSI down: Return=ignore -->
        <!-- plus the VSCODEPATH condition below give two layers of       -->
        <!-- safety.                                                      -->
        <CustomAction Id='InstallVSIX'
            Directory='APPLICATIONFOLDER'
            ExeCommand='cmd.exe /c ""[VSCODEPATH]bin\code.cmd" --install-extension "[APPLICATIONFOLDER]parkyoungung.prsm-lang.vsix" --force"'
            Execute='deferred'
            Impersonate='yes'
            Return='ignore' />

        <InstallExecuteSequence>
            <Custom Action='InstallVSIX' Before='InstallFinalize'>
                <![CDATA[NOT Installed AND &VSCodeExtension = 3 AND VSCODEPATH]]>
            </Custom>
        </InstallExecuteSequence>

        <!-- ========================================================== -->
        <!-- UI: Minimal with completion message                         -->
        <!-- ========================================================== -->

        <UIRef Id='WixUI_Minimal' />
        <WixVariable Id='WixUILicenseRtf' Value='crates\refraction\wix\License.rtf' />

        <Property Id='WIXUI_EXITDIALOGOPTIONALTEXT'
            Value='PrSM has been installed successfully.&#13;&#10;&#13;&#10;VS Code extension: If automatic installation was skipped (VS Code not detected) or failed, the VSIX is available at:&#13;&#10;  [APPLICATIONFOLDER]parkyoungung.prsm-lang.vsix&#13;&#10;Install it manually via VS Code: Extensions > Â·Â·Â· > Install from VSIX.&#13;&#10;&#13;&#10;To install the Unity package, open Unity and go to:&#13;&#10;Window > Package Manager > + > Add package from git URL:&#13;&#10;https://github.com/29thnight/PrSM.git?path=unity-package' />

    </Product>
</Wix>
